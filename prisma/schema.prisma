generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  goal          String    @default("mantener")
  dailyCalories Int       @default(2200)
  weight        Int       @default(70)
  height        Int       @default(170)
  age           Int       @default(30)
  sex           String    @default("male")
  activity      String    @default("moderado")
  createdAt     DateTime  @default(now())
  meals         Meal[]
  sessions      Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Meal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  calories  Int
  protein   Int
  carbs     Int
  fat       Int
  items     Json
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
